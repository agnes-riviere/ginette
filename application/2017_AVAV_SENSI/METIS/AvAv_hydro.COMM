        points 48.000 79.800  6.000 79.810  27.000 78.549 # surface topo
      fin_val

	   potentiel contour
	  val = 78.069550000000007
	 points  6.000 79.810  6.000 76.830  6.000 78.320 #coté droit vertical
      fin_val

   potentiel contour
